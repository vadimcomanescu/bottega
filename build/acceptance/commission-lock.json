{
  "name": "Commission lock",
  "scenarios": [
    {
      "name": "Signing writes a lock that covers every feature file",
      "steps": [
        {
          "keyword": "Given",
          "text": "a repo with feature files \"login.feature\" and \"billing.feature\""
        },
        {
          "keyword": "When",
          "text": "I run \"bottega sign\""
        },
        {
          "keyword": "Then",
          "text": "the lock records \u003ccount\u003e files",
          "parameters": [
            "count"
          ]
        },
        {
          "keyword": "And",
          "text": "the lock entry for \"login.feature\" matches its content hash"
        }
      ],
      "examples": [
        {
          "count": "2"
        }
      ]
    },
    {
      "name": "Verifying an untouched commission passes",
      "steps": [
        {
          "keyword": "Given",
          "text": "a signed repo containing \"login.feature\""
        },
        {
          "keyword": "When",
          "text": "I run \"bottega verify\""
        },
        {
          "keyword": "Then",
          "text": "it exits with \u003cexit\u003e",
          "parameters": [
            "exit"
          ]
        }
      ],
      "examples": [
        {
          "exit": "0"
        }
      ]
    },
    {
      "name": "Drift after sign-off fails verification",
      "steps": [
        {
          "keyword": "Given",
          "text": "a signed repo containing \"\u003cfile\u003e\"",
          "parameters": [
            "file"
          ]
        },
        {
          "keyword": "When",
          "text": "the file \"\u003cfile\u003e\" is \u003cchange\u003e",
          "parameters": [
            "file",
            "change"
          ]
        },
        {
          "keyword": "And",
          "text": "I run \"bottega verify\""
        },
        {
          "keyword": "Then",
          "text": "it exits with \u003cexit\u003e",
          "parameters": [
            "exit"
          ]
        },
        {
          "keyword": "And",
          "text": "the report marks \"\u003cfile\u003e\" as \"\u003cstatus\u003e\"",
          "parameters": [
            "file",
            "status"
          ]
        }
      ],
      "examples": [
        {
          "change": "modified",
          "exit": "1",
          "file": "login.feature",
          "status": "modified"
        },
        {
          "change": "deleted",
          "exit": "1",
          "file": "login.feature",
          "status": "removed"
        }
      ]
    },
    {
      "name": "A feature file added after sign-off is drift",
      "steps": [
        {
          "keyword": "Given",
          "text": "a signed repo containing \"login.feature\""
        },
        {
          "keyword": "When",
          "text": "a new feature file \"\u003cnewfile\u003e\" is added",
          "parameters": [
            "newfile"
          ]
        },
        {
          "keyword": "And",
          "text": "I run \"bottega verify\""
        },
        {
          "keyword": "Then",
          "text": "it exits with \u003cexit\u003e",
          "parameters": [
            "exit"
          ]
        },
        {
          "keyword": "And",
          "text": "the report marks \"\u003cnewfile\u003e\" as \"\u003cstatus\u003e\"",
          "parameters": [
            "newfile",
            "status"
          ]
        }
      ],
      "examples": [
        {
          "exit": "1",
          "newfile": "extra.feature",
          "status": "added"
        }
      ]
    },
    {
      "name": "Verifying an unsigned repo fails loudly",
      "steps": [
        {
          "keyword": "Given",
          "text": "a repo with feature files \"login.feature\" and \"billing.feature\""
        },
        {
          "keyword": "When",
          "text": "I run \"bottega verify\""
        },
        {
          "keyword": "Then",
          "text": "it exits with \u003cexit\u003e",
          "parameters": [
            "exit"
          ]
        }
      ],
      "examples": [
        {
          "exit": "2"
        }
      ]
    }
  ]
}
