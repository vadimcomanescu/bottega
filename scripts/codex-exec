#!/usr/bin/env node

// The one place a codex worker is launched. Callers never assemble
// `codex exec` themselves: the flags that make a dispatch run identically on
// any host (--ignore-user-config, the sandbox, the captured event stream)
// and the resume traps (resume silently drops -s and -C, so the sandbox must
// re-enter as -c sandbox_mode and the worktree as the process cwd) are
// encoded here once.
//
//   codex-exec --model <model> --effort <level> \
//              --sandbox <read-only|danger-full-access> --cwd <worktree> \
//              --brief <file> --out <file> --events <file> \
//              [--schema <file>] [--resume <thread-id>] [--dry-run]
//
// codex reads the brief file on stdin; the --json event stream lands in the
// events file; the final message lands in the out file. The exit code is
// codex's own. --dry-run prints the assembled invocation as JSON and runs
// nothing.

import { spawnSync } from "node:child_process";
import { existsSync, openSync, readFileSync } from "node:fs";
import { isAbsolute } from "node:path";
import { parseArgs } from "node:util";

const SANDBOXES = new Set(["read-only", "danger-full-access"]);

let values;
try {
  ({ values } = parseArgs({
    options: {
      model: { type: "string" },
      effort: { type: "string" },
      sandbox: { type: "string" },
      cwd: { type: "string" },
      brief: { type: "string" },
      out: { type: "string" },
      events: { type: "string" },
      schema: { type: "string" },
      resume: { type: "string" },
      "dry-run": { type: "boolean", default: false },
    },
  }));
} catch (error) {
  process.stderr.write(String(error.message) + "\n");
  process.exit(2);
}

for (const name of ["model", "effort", "sandbox", "cwd", "brief", "out", "events"]) {
  if (!values[name]) {
    process.stderr.write("codex-exec: --" + name + " is required\n");
    process.exit(2);
  }
}
if (!SANDBOXES.has(values.sandbox)) {
  process.stderr.write(
    "codex-exec: --sandbox must be read-only or danger-full-access\n"
  );
  process.exit(2);
}

// An empty optional flag would silently degrade: --resume "" becomes a fresh
// dispatch, --schema "" an unenforced one.
for (const name of ["schema", "resume"]) {
  if (values[name] === "") {
    process.stderr.write("codex-exec: --" + name + " must not be empty\n");
    process.exit(2);
  }
}
// A relative path resolves against the dispatching shell's cwd, so a worker
// can silently run against the wrong tree; every path is absolute or refused.
for (const name of ["cwd", "brief", "out", "events", "schema"]) {
  if (values[name] !== undefined && !isAbsolute(values[name])) {
    process.stderr.write("codex-exec: --" + name + " must be an absolute path\n");
    process.exit(2);
  }
}

const argv = ["exec"];
if (values.resume) argv.push("resume", values.resume);
argv.push(
  "--ignore-user-config",
  "-m", values.model,
  "-c", "model_reasoning_effort=" + values.effort
);
if (values.resume) {
  // resume drops -s and -C: sandbox re-enters as config, cwd as process cwd.
  argv.push("-c", "sandbox_mode=" + values.sandbox);
} else {
  argv.push("-s", values.sandbox, "-C", values.cwd);
}
argv.push("--json", "-o", values.out);
if (values.schema) argv.push("--output-schema", values.schema);
if (values.resume) argv.push("-"); // resume's read-the-brief-from-stdin marker

if (values["dry-run"]) {
  process.stdout.write(
    JSON.stringify({
      command: "codex",
      argv,
      stdin: values.brief,
      stdout: values.events,
      cwd: values.cwd,
    }) + "\n"
  );
  process.exit(0);
}

for (const name of ["cwd", "brief", ...(values.schema ? ["schema"] : [])]) {
  if (!existsSync(values[name])) {
    process.stderr.write("codex-exec: --" + name + " " + values[name] + " does not exist\n");
    process.exit(2);
  }
}

const result = spawnSync("codex", argv, {
  cwd: values.cwd,
  stdio: [openSync(values.brief, "r"), openSync(values.events, "w"), "inherit"],
});
if (result.error) {
  process.stderr.write("codex-exec: " + result.error.message + "\n");
  process.exit(1);
}

function fail(message) {
  process.stderr.write("codex-exec: " + message + "\n");
  process.exit(1);
}

// The event stream is the completion authority: a run finished when it
// emitted turn.completed, and a failed run names its reason in error and
// turn.failed events. Exit code and stream EOF alone prove neither.
let events = [];
try {
  events = readFileSync(values.events, "utf8")
    .split("\n")
    .map((line) => {
      try {
        return JSON.parse(line);
      } catch {
        return null;
      }
    })
    .filter((event) => event && typeof event.type === "string");
} catch {}

const status = result.status ?? 1;
if (status !== 0) {
  const failure = events.findLast(
    (event) => event.type === "turn.failed" || event.type === "error"
  );
  const message = failure?.error?.message ?? failure?.message;
  if (message) process.stderr.write("codex-exec: " + message + "\n");
  process.exit(status);
}

// A resumed thread echoes its id in thread.started; a different id means
// the thread was gone and codex forked a fresh session with none of the
// context the resume was for.
const started = events.find((event) => event.type === "thread.started");
if (values.resume && started && started.thread_id !== values.resume) {
  fail(
    "resume of thread " + values.resume + " started a new session " +
      started.thread_id + " instead; the thread no longer exists, re-dispatch fresh"
  );
}
if (!events.some((event) => event.type === "turn.completed")) {
  fail("codex exited 0 without a turn.completed event; the run did not finish");
}

// -o and --output-schema both survive resume, so every clean exit must have
// written the final message, and a schema'd dispatch parseable JSON.
let final = "";
try {
  final = readFileSync(values.out, "utf8");
} catch {}
if (!final.trim()) fail("codex exited 0 but wrote no final message to --out");
if (values.schema) {
  try {
    JSON.parse(final);
  } catch {
    fail("the --out file is not valid JSON despite --schema; treat the dispatch as failed");
  }
}
process.exit(0);
