#!/usr/bin/env node

// The one place a codex worker is launched. Callers never assemble
// `codex exec` themselves: the flags that make a dispatch run identically on
// any host (--ignore-user-config, the sandbox, the captured event stream)
// and the resume traps (resume silently drops -s and -C, so the sandbox must
// re-enter as -c sandbox_mode and the worktree as the process cwd) are
// encoded here once.
//
//   codex-exec --model <model> --effort <level> \
//              --sandbox <read-only|danger-full-access> --cwd <worktree> \
//              --brief <file> --out <file> --events <file> \
//              [--schema <file>] [--resume <thread-id>] [--dry-run]
//
// codex reads the brief file on stdin; the --json event stream lands in the
// events file; the final message lands in the out file. A run whose events
// file stops growing for CODEX_EXEC_STALL_MS (default five minutes) is
// killed as hung. --dry-run prints the assembled invocation as JSON and runs
// nothing.

import { spawn } from "node:child_process";
import { createWriteStream, existsSync, openSync, readFileSync, writeFileSync } from "node:fs";
import { isAbsolute } from "node:path";
import { StringDecoder } from "node:string_decoder";
import { parseArgs } from "node:util";

// Progress and heartbeat emission must never change dispatch semantics: if the
// consumer closes stderr, swallow the EPIPE instead of dying on an unhandled
// stream error mid-run.
process.stderr.on("error", () => {});

const SANDBOXES = new Set(["read-only", "danger-full-access"]);

let values;
try {
  ({ values } = parseArgs({
    options: {
      model: { type: "string" },
      effort: { type: "string" },
      sandbox: { type: "string" },
      cwd: { type: "string" },
      brief: { type: "string" },
      out: { type: "string" },
      events: { type: "string" },
      schema: { type: "string" },
      resume: { type: "string" },
      "dry-run": { type: "boolean", default: false },
    },
  }));
} catch (error) {
  process.stderr.write(String(error.message) + "\n");
  process.exit(2);
}

for (const name of ["model", "effort", "sandbox", "cwd", "brief", "out", "events"]) {
  if (!values[name]) {
    process.stderr.write("codex-exec: --" + name + " is required\n");
    process.exit(2);
  }
}
if (!SANDBOXES.has(values.sandbox)) {
  process.stderr.write(
    "codex-exec: --sandbox must be read-only or danger-full-access\n"
  );
  process.exit(2);
}

// An empty optional flag would silently degrade: --resume "" becomes a fresh
// dispatch, --schema "" an unenforced one.
for (const name of ["schema", "resume"]) {
  if (values[name] === "") {
    process.stderr.write("codex-exec: --" + name + " must not be empty\n");
    process.exit(2);
  }
}
// A relative path resolves against the dispatching shell's cwd, so a worker
// can silently run against the wrong tree; every path is absolute or refused.
for (const name of ["cwd", "brief", "out", "events", "schema"]) {
  if (values[name] !== undefined && !isAbsolute(values[name])) {
    process.stderr.write("codex-exec: --" + name + " must be an absolute path\n");
    process.exit(2);
  }
}

const argv = ["exec"];
if (values.resume) argv.push("resume", values.resume);
argv.push(
  "--ignore-user-config",
  "-m", values.model,
  "-c", "model_reasoning_effort=" + values.effort
);
if (values.resume) {
  // resume drops -s and -C: sandbox re-enters as config, cwd as process cwd.
  argv.push("-c", "sandbox_mode=" + values.sandbox);
} else {
  argv.push("-s", values.sandbox, "-C", values.cwd);
}
argv.push("--json", "-o", values.out);
if (values.schema) argv.push("--output-schema", values.schema);
if (values.resume) argv.push("-"); // resume's read-the-brief-from-stdin marker

if (values["dry-run"]) {
  process.stdout.write(
    JSON.stringify({
      command: "codex",
      argv,
      stdin: values.brief,
      stdout: values.events,
      cwd: values.cwd,
    }) + "\n"
  );
  process.exit(0);
}

function fail(message, code = 1) {
  process.stderr.write("codex-exec: " + message + "\n");
  process.exit(code);
}

for (const name of ["cwd", "brief", ...(values.schema ? ["schema"] : [])]) {
  if (!existsSync(values[name])) fail("--" + name + " " + values[name] + " does not exist", 2);
}

// Both output files start empty: a stale final message from a prior dispatch
// at the same path must never pass verification.
writeFileSync(values.out, "");

const STALL_MS = Number(process.env.CODEX_EXEC_STALL_MS) || 300000;
const HEARTBEAT_MS = Number(process.env.CODEX_EXEC_HEARTBEAT_MS) || 60000;

// stdout is piped through this process, not wired straight to the events
// file. Every raw line is appended verbatim, so the on-disk record stays
// byte-identical (malformed and unknown lines included), and each line is
// also parsed for a human-readable progress line on stderr. The stream is
// flushed and closed before the post-run read so no buffered line is lost.
const eventsStream = createWriteStream(values.events, { flags: "w" });

const startedAt = Date.now();
const child = spawn("codex", argv, {
  cwd: values.cwd,
  stdio: [openSync(values.brief, "r"), "pipe", "inherit"],
});
child.stdout.on("error", () => {}); // a killed child destroys the read side
// The events file is the run's record. If writing it fails (disk full, an I/O
// error), the dispatch cannot be verified: kill codex so it is not orphaned
// and fail cleanly, rather than crash the parent with an uncaught error.
eventsStream.on("error", (error) => {
  try {
    child.kill("SIGKILL");
  } catch {}
  fail("events file " + values.events + " write failed: " + error.message);
});

function note(text) {
  process.stderr.write("codex-exec: " + text + "\n");
}

// codex output can carry ANSI/OSC control sequences that manipulate the
// terminal. Strip ESC-based sequences and C0 control characters (keeping tab
// and newline) from every codex-supplied field before it reaches stderr. The
// events file keeps the original bytes; only the display is escaped.
function clean(text) {
  return String(text)
    .replace(/\x1b\][\s\S]*?(?:\x07|\x1b\\)/g, "") // OSC ... BEL or ST
    .replace(/\x1b[@-Z\\-_]|\x1b\[[0-?]*[ -/]*[@-~]/g, "") // Fe escapes and CSI
    .replace(/\x1b/g, "") // any stray ESC
    .replace(/[\x00-\x08\x0b\x0c\x0e-\x1f\x7f]/g, ""); // C0 controls, keep \t \n
}

// Progress is display-only. A malformed, unknown, or reshaped event prints
// nothing and can never throw, change the exit code, or corrupt the record;
// only the post-run event-stream read below decides exit semantics.
function emitProgress(line) {
  let event;
  try {
    event = JSON.parse(line);
  } catch {
    return;
  }
  try {
    describeEvent(event);
  } catch {}
}

// A reshaped event (a load-bearing field of the wrong shape) prints nothing:
// each branch validates the fields it needs before displaying, so no branch
// fabricates a value. Display never affects exit semantics; only the post-run
// event-stream read below does.
function describeEvent(event) {
  if (!event || typeof event.type !== "string") return;
  switch (event.type) {
    case "thread.started":
      if (typeof event.thread_id !== "string") return;
      note("thread " + clean(event.thread_id));
      return;
    case "item.completed": {
      const item = event.item;
      if (!item || typeof item.type !== "string") return;
      if (item.type === "command_execution") {
        if (typeof item.command !== "string" || !Number.isInteger(item.exit_code)) return;
        const command = clean(item.command).replace(/\s+/g, " ").trim();
        note("$ " + command.slice(0, 200) + " (exit " + item.exit_code + ")");
      } else if (item.type === "agent_message") {
        if (typeof item.text !== "string") return;
        process.stderr.write("codex-exec: agent:\n" + clean(item.text) + "\n");
      } else if (item.type === "file_change") {
        const changes = Array.isArray(item.changes) ? item.changes : [];
        const paths = changes
          .map((change) => change && change.path)
          .filter((path) => typeof path === "string" && path.length > 0);
        if (paths.length === 0) return;
        note("files " + paths.map(clean).join(", "));
      }
      return;
    }
    case "turn.completed": {
      const usage = event.usage;
      if (!usage || typeof usage !== "object") return;
      const fields = [
        usage.input_tokens,
        usage.output_tokens,
        usage.cached_input_tokens,
        usage.reasoning_output_tokens,
      ];
      if (fields.some((n) => typeof n !== "number")) return;
      note(
        "turn complete, tokens in=" + usage.input_tokens +
          " out=" + usage.output_tokens +
          " cached=" + usage.cached_input_tokens +
          " reasoning=" + usage.reasoning_output_tokens
      );
      return;
    }
    case "turn.failed":
    case "error": {
      const reason =
        typeof event.error === "string"
          ? event.error
          : event.error?.message ?? event.message;
      if (typeof reason === "string" && reason) note(clean(reason));
      return;
    }
  }
}

const decoder = new StringDecoder("utf8");
let buffer = "";
let lastData = startedAt;
let stalled = false;

function onStdout(chunk) {
  // Any bytes count as liveness, so a large event streamed slowly across
  // chunks is never killed as stalled mid-arrival.
  lastData = Date.now();
  eventsStream.write(chunk);
  buffer += decoder.write(chunk);
  let index;
  while ((index = buffer.indexOf("\n")) !== -1) {
    const line = buffer.slice(0, index);
    buffer = buffer.slice(index + 1);
    if (line.length > 0) emitProgress(line);
  }
}
child.stdout.on("data", onStdout);
child.stdout.on("end", () => {
  buffer += decoder.end();
  if (buffer.length > 0) emitProgress(buffer);
});

// A wedged codex sits alive at 0% CPU forever and never exits into the
// caller's process tracking; bytes arriving on stdout are the liveness signal.
const stallWatchdog = setInterval(() => {
  if (Date.now() - lastData >= STALL_MS) {
    stalled = true;
    child.kill("SIGKILL");
  }
}, Math.min(15000, Math.max(50, Math.floor(STALL_MS / 5))));

const heartbeat = setInterval(() => {
  const idle = Date.now() - lastData;
  if (idle >= HEARTBEAT_MS)
    note(
      "still running, " + Math.round((Date.now() - startedAt) / 1000) +
        "s elapsed, last event " + Math.round(idle / 1000) + "s ago"
    );
}, HEARTBEAT_MS);

const [status, spawnError] = await new Promise((resolve) => {
  child.on("error", (error) => resolve([1, error]));
  // exit fires when codex itself ends. close is withheld until every process
  // holding the piped stdout fd releases it, and under danger-full-access a
  // descendant that inherited fd 1 can hold it open forever, past a SIGKILL of
  // codex, so completion keys on exit to keep the watchdog's kill effective.
  child.on("exit", (code) => resolve([code ?? 1, null]));
});
clearInterval(stallWatchdog);
clearInterval(heartbeat);
// codex has exited. Drain stdout still buffered in the pipe so the record
// stays complete, but bound the wait: a surviving descendant holding the pipe
// open would otherwise stall this read forever.
if (!child.stdout.readableEnded)
  await new Promise((resolve) => {
    child.stdout.once("end", resolve);
    child.stdout.once("close", resolve);
    setTimeout(resolve, 2000).unref();
  });
// Detach and destroy stdout before ending the events stream. A descendant that
// inherited fd 1 can hold the pipe open past codex's exit; without this a late
// chunk would reach the ended stream (ERR_STREAM_WRITE_AFTER_END, which the
// error handler turns into a SIGKILL and a nonzero exit for a finished run) and
// the live handle would keep the event loop alive. Execution then continues
// synchronously to the verification, so no path exits before the fail() checks.
child.stdout.removeListener("data", onStdout);
child.stdout.destroy();
await new Promise((resolve) => eventsStream.end(resolve));
if (spawnError) fail(spawnError.message);
if (stalled)
  fail(
    "killed after " + Math.round(STALL_MS / 1000) +
      "s without event activity; the run was hung, resume the thread to continue"
  );

// The event stream is the completion authority: a run finished when it
// emitted turn.completed, and a failed run names its reason in error and
// turn.failed events. Exit code and stream EOF alone prove neither.
const RELEVANT = /"type":\s*"(thread\.started|turn\.completed|turn\.failed|error)"/;
const events = readFileSync(values.events, "utf8")
  .split("\n")
  .filter((line) => RELEVANT.test(line))
  .map((line) => {
    try {
      return JSON.parse(line);
    } catch {
      return null;
    }
  })
  .filter((event) => event && typeof event.type === "string");

const failure = events.findLast(
  (event) => event.type === "turn.failed" || event.type === "error"
);
const reason =
  typeof failure?.error === "string"
    ? failure.error
    : failure?.error?.message ?? failure?.message;

if (status !== 0) {
  if (reason) process.stderr.write("codex-exec: " + clean(reason) + "\n");
  process.exit(status);
}

// A resumed thread echoes its id in thread.started; a different or missing
// id means codex forked a fresh session with none of the context the resume
// was for, and the fork may have touched the worktree before this check.
const started = events.find((event) => event.type === "thread.started");
if (values.resume) {
  if (!started) fail("resume of thread " + values.resume + " emitted no thread.started event; re-dispatch fresh");
  if (started.thread_id !== values.resume)
    fail(
      "resume of thread " + values.resume + " started a new session " +
        clean(started.thread_id) + " instead; the thread no longer exists and the forked session may have modified the worktree, re-dispatch fresh"
    );
}
if (!events.some((event) => event.type === "turn.completed"))
  fail(
    "codex exited 0 without a turn.completed event; the run did not finish" +
      (reason ? " (last failure event: " + clean(reason) + ")" : "")
  );

// -o and --output-schema both survive resume, so every clean exit must have
// written the final message, and a schema'd dispatch parseable JSON.
const final = readFileSync(values.out, "utf8");
if (!final.trim()) fail("codex exited 0 but wrote no final message to --out");
if (values.schema) {
  try {
    JSON.parse(final);
  } catch {
    fail("the --out file is not valid JSON despite --schema; treat the dispatch as failed");
  }
}
process.exit(0);
