#!/usr/bin/env node

// The one place a codex worker is launched. Callers never assemble
// `codex exec` themselves: the flags that make a dispatch run identically on
// any host (--ignore-user-config, the sandbox, the captured event stream)
// and the resume traps (resume silently drops -s and -C, so the sandbox must
// re-enter as -c sandbox_mode and the worktree as the process cwd) are
// encoded here once.
//
//   codex-exec --model <model> --effort <level> \
//              --sandbox <read-only|danger-full-access> --cwd <worktree> \
//              --brief <file> --out <file> --events <file> \
//              [--schema <file>] [--resume <thread-id>] [--dry-run]
//
// codex reads the brief file on stdin; the --json event stream lands in the
// events file; the final message lands in the out file. A run whose events
// file stops growing for CODEX_EXEC_STALL_MS (default five minutes) is
// killed as hung. --dry-run prints the assembled invocation as JSON and runs
// nothing.

import { spawn } from "node:child_process";
import { existsSync, openSync, readFileSync, statSync, writeFileSync } from "node:fs";
import { isAbsolute } from "node:path";
import { parseArgs } from "node:util";

const SANDBOXES = new Set(["read-only", "danger-full-access"]);

let values;
try {
  ({ values } = parseArgs({
    options: {
      model: { type: "string" },
      effort: { type: "string" },
      sandbox: { type: "string" },
      cwd: { type: "string" },
      brief: { type: "string" },
      out: { type: "string" },
      events: { type: "string" },
      schema: { type: "string" },
      resume: { type: "string" },
      "dry-run": { type: "boolean", default: false },
    },
  }));
} catch (error) {
  process.stderr.write(String(error.message) + "\n");
  process.exit(2);
}

for (const name of ["model", "effort", "sandbox", "cwd", "brief", "out", "events"]) {
  if (!values[name]) {
    process.stderr.write("codex-exec: --" + name + " is required\n");
    process.exit(2);
  }
}
if (!SANDBOXES.has(values.sandbox)) {
  process.stderr.write(
    "codex-exec: --sandbox must be read-only or danger-full-access\n"
  );
  process.exit(2);
}

// An empty optional flag would silently degrade: --resume "" becomes a fresh
// dispatch, --schema "" an unenforced one.
for (const name of ["schema", "resume"]) {
  if (values[name] === "") {
    process.stderr.write("codex-exec: --" + name + " must not be empty\n");
    process.exit(2);
  }
}
// A relative path resolves against the dispatching shell's cwd, so a worker
// can silently run against the wrong tree; every path is absolute or refused.
for (const name of ["cwd", "brief", "out", "events", "schema"]) {
  if (values[name] !== undefined && !isAbsolute(values[name])) {
    process.stderr.write("codex-exec: --" + name + " must be an absolute path\n");
    process.exit(2);
  }
}

const argv = ["exec"];
if (values.resume) argv.push("resume", values.resume);
argv.push(
  "--ignore-user-config",
  "-m", values.model,
  "-c", "model_reasoning_effort=" + values.effort
);
if (values.resume) {
  // resume drops -s and -C: sandbox re-enters as config, cwd as process cwd.
  argv.push("-c", "sandbox_mode=" + values.sandbox);
} else {
  argv.push("-s", values.sandbox, "-C", values.cwd);
}
argv.push("--json", "-o", values.out);
if (values.schema) argv.push("--output-schema", values.schema);
if (values.resume) argv.push("-"); // resume's read-the-brief-from-stdin marker

if (values["dry-run"]) {
  process.stdout.write(
    JSON.stringify({
      command: "codex",
      argv,
      stdin: values.brief,
      stdout: values.events,
      cwd: values.cwd,
    }) + "\n"
  );
  process.exit(0);
}

function fail(message, code = 1) {
  process.stderr.write("codex-exec: " + message + "\n");
  process.exit(code);
}

for (const name of ["cwd", "brief", ...(values.schema ? ["schema"] : [])]) {
  if (!existsSync(values[name])) fail("--" + name + " " + values[name] + " does not exist", 2);
}

// Both output files start empty: a stale final message from a prior dispatch
// at the same path must never pass verification.
writeFileSync(values.out, "");

const STALL_MS = Number(process.env.CODEX_EXEC_STALL_MS) || 300000;

const child = spawn("codex", argv, {
  cwd: values.cwd,
  stdio: [openSync(values.brief, "r"), openSync(values.events, "w"), "inherit"],
});

// A wedged codex sits alive at 0% CPU forever and never exits into the
// caller's process tracking; the events file is the liveness signal.
let lastSize = -1;
let lastGrowth = Date.now();
let stalled = false;
const watchdog = setInterval(() => {
  let size = 0;
  try {
    size = statSync(values.events).size;
  } catch {}
  if (size > lastSize) {
    lastSize = size;
    lastGrowth = Date.now();
  } else if (Date.now() - lastGrowth >= STALL_MS) {
    stalled = true;
    child.kill("SIGKILL");
  }
}, Math.min(15000, Math.max(50, Math.floor(STALL_MS / 5))));

const [status, spawnError] = await new Promise((resolve) => {
  child.on("error", (error) => resolve([1, error]));
  child.on("close", (code) => resolve([code ?? 1, null]));
});
clearInterval(watchdog);
if (spawnError) fail(spawnError.message);
if (stalled)
  fail(
    "killed after " + Math.round(STALL_MS / 1000) +
      "s without event activity; the run was hung, resume the thread to continue"
  );

// The event stream is the completion authority: a run finished when it
// emitted turn.completed, and a failed run names its reason in error and
// turn.failed events. Exit code and stream EOF alone prove neither.
const RELEVANT = /"type":\s*"(thread\.started|turn\.completed|turn\.failed|error)"/;
const events = readFileSync(values.events, "utf8")
  .split("\n")
  .filter((line) => RELEVANT.test(line))
  .map((line) => {
    try {
      return JSON.parse(line);
    } catch {
      return null;
    }
  })
  .filter((event) => event && typeof event.type === "string");

const failure = events.findLast(
  (event) => event.type === "turn.failed" || event.type === "error"
);
const reason =
  typeof failure?.error === "string"
    ? failure.error
    : failure?.error?.message ?? failure?.message;

if (status !== 0) {
  if (reason) process.stderr.write("codex-exec: " + reason + "\n");
  process.exit(status);
}

// A resumed thread echoes its id in thread.started; a different or missing
// id means codex forked a fresh session with none of the context the resume
// was for, and the fork may have touched the worktree before this check.
const started = events.find((event) => event.type === "thread.started");
if (values.resume) {
  if (!started) fail("resume of thread " + values.resume + " emitted no thread.started event; re-dispatch fresh");
  if (started.thread_id !== values.resume)
    fail(
      "resume of thread " + values.resume + " started a new session " +
        started.thread_id + " instead; the thread no longer exists and the forked session may have modified the worktree, re-dispatch fresh"
    );
}
if (!events.some((event) => event.type === "turn.completed"))
  fail(
    "codex exited 0 without a turn.completed event; the run did not finish" +
      (reason ? " (last failure event: " + reason + ")" : "")
  );

// -o and --output-schema both survive resume, so every clean exit must have
// written the final message, and a schema'd dispatch parseable JSON.
const final = readFileSync(values.out, "utf8");
if (!final.trim()) fail("codex exited 0 but wrote no final message to --out");
if (values.schema) {
  try {
    JSON.parse(final);
  } catch {
    fail("the --out file is not valid JSON despite --schema; treat the dispatch as failed");
  }
}
process.exit(0);
